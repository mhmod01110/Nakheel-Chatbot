APP_NAME=Nakheel RAG Chatbot
APP_ENV=development
APP_PORT=7000
APP_VERSION=1.0.0
APP_SECRET_KEY=replace-with-a-long-random-secret
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=nakheel_db

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=nakheel_chunks
QDRANT_USE_HTTPS=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1024
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.3

BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BGE_USE_FP16=false

PDF_PARSER_BACKEND=pypdf
PDF_ENABLE_OCR=false
PDF_ENABLE_TABLE_STRUCTURE=false

CHUNK_MAX_TOKENS=512
CHUNK_MIN_TOKENS=50
CHUNK_OVERLAP_RATIO=0.20

DENSE_TOP_K=20
SPARSE_TOP_K=20
RRF_K=60
RRF_TOP_N=10
RERANKER_TOP_K=5
RELEVANCE_THRESHOLD=0.35
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3

SESSION_MAX_MESSAGES=10
SESSION_TTL_HOURS=24
TOKEN_BUDGET_HISTORY=2000

MAX_FILE_SIZE_MB=50
TEMP_DIR=/tmp/nakheel
PARSED_FILE_TTL_HOURS=2

RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_INJECT_PER_HOUR=10
